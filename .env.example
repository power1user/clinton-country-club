# Windhaven — environment variables
# Copy this file to `.env.local` and fill in real values. .env.local is gitignored.
#
# Supabase (from Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# MapTiler (from maptiler.com → Account → API keys) — for the course satellite map
VITE_MAPTILER_KEY=

# OpenWeatherMap (from openweathermap.org → My API keys) — needed for the weather widget
VITE_OPENWEATHER_API_KEY=

# Web Push — VAPID public key (safe to ship; generate via `npx web-push generate-vapid-keys`).
# The matching VAPID_PRIVATE_KEY must be set as a Supabase Edge Function secret.
VITE_VAPID_PUBLIC_KEY=

# Default club slug — the app picks which club to load by slug.
# In Phase 3 this becomes a fallback used only in dev / preview;
# production resolves the slug from the subdomain (e.g. clintoncc.groundslive.com).
VITE_DEFAULT_CLUB_SLUG=clintoncc
